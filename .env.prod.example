# Server .env template for docker-compose.prod.yml (C5). Copy to `.env` on the
# home server and fill in real secrets. NEVER commit the real .env.
#
# Note: DATABASE_URL / REDIS_HOST / REDIS_PORT / UPLOAD_DIR are set by the
# compose file (they wire to the postgres/redis services), so they are
# intentionally NOT listed here — don't add them or you'll fight the compose
# overrides.

# --- Postgres (consumed by compose interpolation + the postgres service) ---
POSTGRES_PASSWORD=generate-a-strong-password

# --- Auth (app refuses to boot without JWT_SECRET) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=generate-a-strong-random-string
JWT_EXPIRY_DAYS=30

# --- Encryption key for stored OAuth tokens ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=generate-a-fernet-key

# --- LLM (self-hosted llama_cpp) ---
LLM_BACKEND=llama_cpp
LLM_ENDPOINT=http://your-llm-host:8080/v1
LLM_MODEL=qwen3.5-9b-q4
LLM_TIMEOUT_S=60
# Rows per categorize LLM call (default 20 if unset). Set to 1 for deterministic
# categorization on a bulk backfill (GPT-OSS varies with batch position, #64).
LLM_BATCH_SIZE=1

# --- Misc ---
# Frontend origin(s) allowed by CORS (comma-separated).
CORS_ORIGINS=https://your-frontend-origin
JOB_RUNNER=thread
APP_LOG_LEVEL=INFO
THIRD_PARTY_LOG_LEVEL=WARNING

# --- Grafana (log dashboard) ---
GRAFANA_PASSWORD=generate-a-strong-password
