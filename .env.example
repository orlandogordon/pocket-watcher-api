# Example environment file. Copy to `.env` and fill in real values.
# `.env` is gitignored; this file is committed as a reference.

# Auth

# Secret used to sign + verify JWTs. App refuses to boot if missing.
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars
JWT_EXPIRY_DAYS=30

# Database

# For Postgres: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///test.db
SQL_ECHO=false

# Redis (preview-session storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# LLM

LLM_BACKEND=llama_cpp
# When the API runs on a different machine than the LLM, point this at the
# LLM host's LAN IP, e.g. http://192.168.1.42:8080/v1
LLM_ENDPOINT=http://localhost:8080/v1
# For llama-server, must match the --alias flag the server was launched with.
LLM_MODEL=qwen3.5-9b-q4
# First batch on a local 9B is ~24s; raise to 120 for eval/integration tests.
LLM_TIMEOUT_S=15.0
# LLM_API_KEY=

# Misc

CORS_ORIGINS=http://localhost:5173
JOB_RUNNER=thread
APP_LOG_LEVEL=INFO
THIRD_PARTY_LOG_LEVEL=WARNING
# LOG_FILE=
